{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["lint", "build", "sleep"],
  "workspaces": {
    ".": {
      "ignoreDependencies": [
        "prettier"
      ]
    },
    "packages/shared": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"],
      "includeEntryExports": true,
      "ignore": [
        "src/google-iap.ts",
        "src/test-utils.ts"
      ]
    },
    "packages/unleash-v6": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/unleash-v7": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
