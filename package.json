{
  "name": "nais-unleash",
  "version": "4.0.0",
  "description": "NAIS customized Unleash feature flag server - monorepo",
  "private": true,
  "scripts": {
    "db:start": "docker compose up -d postgres && echo 'Waiting for PostgreSQL...' && until docker compose exec -T postgres pg_isready -U unleash > /dev/null 2>&1; do sleep 1; done && echo 'Database ready!'",
    "db:stop": "docker compose down",
    "build:all": "pnpm -r build",
    "build:shared": "pnpm --filter @nais/unleash-shared build",
    "build:v6": "pnpm --filter unleash-v6 build",
    "build:v7": "pnpm --filter unleash-v7 build",
    "pretest:all": "pnpm db:start",
    "test:all": "pnpm -r test",
    "test:shared": "pnpm --filter @nais/unleash-shared test",
    "pretest:v6": "pnpm db:start",
    "test:v6": "pnpm --filter unleash-v6 test",
    "pretest:v7": "pnpm db:start",
    "test:v7": "pnpm --filter unleash-v7 test",
    "lint:all": "pnpm -r lint",
    "lint:shared": "pnpm --filter @nais/unleash-shared lint",
    "lint:v6": "pnpm --filter unleash-v6 lint",
    "lint:v7": "pnpm --filter unleash-v7 lint",
    "knip": "knip"
  },
  "author": "NAIS <aura@nav.no>",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "8.0.16",
    "vitest": "^4.1.8"
  }
}
